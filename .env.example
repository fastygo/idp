# Copy to .env: cp .env.example .env
# Generate secrets: openssl rand -base64 32

# Required: HMAC key for signing IdP session and pending-request cookies
IDP_SESSION_KEY=change-me-to-a-long-random-secret

# Public URLs (must match your TLS / reverse proxy)
IDP_ENTITY_ID=https://idp.example.com
IDP_BASE_URL=https://idp.example.com

# Hanko public API URL (browser + server must reach it)
IDP_HANKO_API_URL=https://api.example.com

# OIDC client secrets (one per registered client, key = OIDC_CLIENT_SECRET_ + uppercase client_id)
OIDC_CLIENT_SECRET_MYAPP=change-me-to-a-long-random-secret
